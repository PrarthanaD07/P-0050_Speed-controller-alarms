import unittest
from app import predict_speed

# Copy same logic here OR import if separated
def check_status(predicted, actual):
    if actual > predicted + 120:
        return "OVER"
    elif actual < predicted - 120:
        return "UNDER"
    else:
        return "NORMAL"


class TestAIMotorSystem(unittest.TestCase):

    def test_ai_prediction(self):
        speed = predict_speed(150)
        self.assertTrue(speed > 1000)

    def test_over_speed(self):
        predicted = 1500
        actual = 1700
        self.assertEqual(check_status(predicted, actual), "OVER")

    def test_under_speed(self):
        predicted = 1500
        actual = 1200
        self.assertEqual(check_status(predicted, actual), "UNDER")

    def test_normal_speed(self):
        predicted = 1500
        actual = 1520
        self.assertEqual(check_status(predicted, actual), "NORMAL")

    def test_edge_case_high(self):
        predicted = 1500
        actual = 1620  # boundary
        self.assertEqual(check_status(predicted, actual), "NORMAL")

    def test_edge_case_low(self):
        predicted = 1500
        actual = 1380  # boundary
        self.assertEqual(check_status(predicted, actual), "NORMAL")


