import unittest
from app import predict_speed

class TestMotorSystem(unittest.TestCase):

    def test_prediction(self):
        result = predict_speed(150)
        self.assertTrue(result > 1000)

    def test_over_speed(self):
        predicted = 1500
        actual = 1700

        status = ""
        if actual > predicted + 120:
            status = "OVER"

        self.assertEqual(status, "OVER")

    def test_under_speed(self):
        predicted = 1500
        actual = 1200

        status = ""
        if actual < predicted - 120:
            status = "UNDER"

        self.assertEqual(status, "UNDER")

    def test_normal_speed(self):
        predicted = 1500
        actual = 1520

        status = ""
        if predicted - 120 <= actual <= predicted + 120:
            status = "NORMAL"

        self.assertEqual(status, "NORMAL")

